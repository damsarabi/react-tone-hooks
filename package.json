{
  "name": "react-tone-hooks",
  "version": "1.0.2",
  "description": "A deterministic audio lifecycle manager for React. Seamlessly bridge React's render cycle with the Tone.js Web Audio API.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damsarabi/react-tone-hooks.git"
  },
  "keywords": [
    "react",
    "tone",
    "audio",
    "webaudio",
    "hooks"
  ],
  "author": "Sam Darabi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/damsarabi/react-tone-hooks/issues"
  },
  "homepage": "https://github.com/damsarabi/react-tone-hooks#readme",
  "peerDependencies": {
    "react": ">=16.8.0",
    "tone": ">=14.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.31",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tone": "^14.9.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
